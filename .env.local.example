# Groq API (powers the Ai chat panel)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: short topic label injected into the ingest LLM prompt.
WIKI_TOPIC=memory as substrate

# Drag-drop ingest (POST /api/ingest) — required to enable the "+ Add source" button
# Fine-grained GitHub PAT with Contents: write and Pull requests: write on this repo.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Optional, defaults to "main"
GITHUB_BASE_BRANCH=
